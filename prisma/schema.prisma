generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Order {
  id                  String    @id               // Shopify GID
  shopifyNumericId    String    @unique            // raw numeric ID from webhook
  shop                String
  name                String                       // e.g. #1001
  customerFirstName   String?
  customerLastName    String?
  customerPhone       String?
  totalAmount         String
  currencyCode        String
  city                String?
  financialStatus     String
  fulfillmentStatus   String?
  isCancelled         Boolean   @default(false)
  isBooked            Boolean   @default(false)
  bookingWeight       String?
  bookingInstructions String?
  bookingFreeCod      String?
  tcsConsignmentNo    String?
  shippingAddress1    String?
  productSummary      String?
  bookedAt            DateTime?
  shopifyFulfillmentId String?
  shipmentStatus      String    @default("BOOKED")
  shopifyCreatedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop])
}

model TcsSettings {
  id                  String    @id @default(cuid())
  shop                String    @unique          // one record per merchant
  bearerToken         String                     // TCS-issued bearer token
  username            String                     // TCS username
  password            String                     // TCS account password
  accessToken         String?                    // received from TCS auth endpoint
  accessTokenExpiry   DateTime?                  // "expiry" field from TCS response
  connectionStatus    String    @default("disconnected") // "connected"|"disconnected"|"error"
  lastApiMessage      String?                    // "message" field from TCS response
  lastAuthAttempt     DateTime?                  // timestamp of most recent auth call
  lastSuccessfulSync  DateTime?                  // set when a booking succeeds
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  costCenterCode       String?
  tcsAccount           String?
  defaultInstructions  String?
  storeLogo            String?

  @@index([shop])
}

model LoadsheetHistory {
  id              String   @id @default(cuid())
  shop            String
  generatedAt     DateTime @default(now())
  label           String   @default("")
  shipmentCount   Int      @default(0)
  totalCod        Float    @default(0)
  totalWeight     Float    @default(0)
  ordersSnapshot  String   @default("[]") // JSON of minimal row data for PDF re-generation

  @@index([shop, generatedAt])
}

model TcsCity {
  id        String   @id @default(cuid())
  shop      String
  cityCode  String
  cityName  String
  createdAt DateTime @default(now())

  @@unique([shop, cityCode])
  @@index([shop])
}

model TcsCostCenter {
  id             String   @id @default(cuid())
  shop           String
  costCenterCode String
  costCenterName String
  costCenterCity String
  phone          String?
  pickupAddress  String?
  returnAddress  String?
  email          String?
  createdAt      DateTime @default(now())

  @@unique([shop, costCenterCode])
  @@index([shop])
}
